// tests/test_lru.npk
use "../src/mem.npk".*;
use "../src/allocator.npk".*;
use "../src/intmap.npk".*;
use "../src/lru.npk".*;

pub func:failsafe = int32(tbb32:err) { exit 1i32; };

pub func:main = int32() {
    // LRU Cache with max capacity 4 (minimum allowed)
    int64:lru = raw lru_create(4i64);
    if (lru == 0i64) { exit 1i32; }

    int32:status = 0i32;
    wild int8->:out_ptr = nodrop alloc(8i64);
    int64:out_addr = (@cast_unchecked<int64>(out_ptr)) & 281474976710655i64;
    
    // Put 4 elements (10, 20, 30, 40)
    drop raw lru_put(lru, 10i64, 100i64);
    drop raw lru_put(lru, 20i64, 200i64);
    drop raw lru_put(lru, 30i64, 300i64);
    drop raw lru_put(lru, 40i64, 400i64);
    
    // Capacity should be full. Order: 40(head) -> 30 -> 20 -> 10(tail)
    if (raw load64(lru + 40i64) != 4i64) { status = 2i32; }
    
    // Access 10 (moves 10 to head) -> Order: 10(head) -> 40 -> 30 -> 20(tail)
    int8:f1 = raw lru_get(lru, 10i64, out_addr);
    if (f1 != 1i8) { status = 3i32; }
    if (raw load64(out_addr) != 100i64) { status = 4i32; }
    
    // Insert 50 (evicts tail which is 20)
    drop raw lru_put(lru, 50i64, 500i64);
    
    // Check 20 is evicted
    int8:f2 = raw lru_get(lru, 20i64, out_addr);
    if (f2 == 1i8) { status = 5i32; }
    
    // Check 10, 30, 40, 50 are present
    int8:f3 = raw lru_get(lru, 10i64, out_addr);
    if (f3 != 1i8) { status = 6i32; }
    int8:f4 = raw lru_get(lru, 30i64, out_addr);
    if (f4 != 1i8) { status = 7i32; }
    int8:f5 = raw lru_get(lru, 50i64, out_addr);
    if (f5 != 1i8) { status = 8i32; }
    
    // Update 30
    drop raw lru_put(lru, 30i64, 301i64);
    int8:f6 = raw lru_get(lru, 30i64, out_addr);
    if (raw load64(out_addr) != 301i64) { status = 9i32; }

    dalloc(out_ptr);
    drop raw lru_destroy(lru);

    exit status;
};
