use "../src/mem.npk".*;
use "../src/allocator.npk".*;
use "../src/intmap.npk".*;
use "../src/lru.npk".*;

pub func:failsafe = int32(tbb32:err) { exit(err => int32); };

pub func:main = int32() {
    int64:lru = raw lru_create(3i64);
    stack int64:out_val = 0i64;
    int64:out_addr = cast_unchecked<int64>(@out_val);
    
    drop raw lru_put(lru, 10i64, 100i64);
    drop raw lru_put(lru, 20i64, 200i64);
    drop raw lru_put(lru, 30i64, 300i64);
    drop raw lru_get(lru, 10i64, out_addr);
    drop raw lru_put(lru, 40i64, 400i64);
    
    int8:f2 = raw lru_get(lru, 20i64, out_addr);
    if (f2 == 1i8) { exit 5i32; }
    exit 0i32;
};
